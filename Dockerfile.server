FROM golang:1.25-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -buildvcs=false -ldflags="-s -w" -o /out/concord-server ./cmd/server

FROM alpine:3.20
RUN adduser -D -u 10001 concord
COPY --from=build /out/concord-server /usr/local/bin/concord-server
COPY --from=build /src/controls /controls
USER concord
EXPOSE 8080
ENTRYPOINT ["/usr/local/bin/concord-server"]
CMD ["--controls=/controls"]
